{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realtimemail.org/schemas/payment-request.schema.json",
  "title": "Realtime Mail Host-Mediated Payment Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "invoiceId", "merchant", "amount", "description", "confirmationUx", "expiresAt"],
  "properties": {
    "kind": {
      "const": "host-mediated-payment-request"
    },
    "invoiceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "merchant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "displayName"],
      "properties": {
        "domain": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "amount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "currency"],
      "properties": {
        "value": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]{0,11})(\\.[0-9]{2})$"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "orderReference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "confirmationUx": {
      "type": "string",
      "enum": ["browser_payment_request", "host_confirmation", "provider_checkout", "qr_code"]
    },
    "fallbackProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["provider_checkout", "qr_code"]
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "qrPayload": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "provider_checkout" } },
            "required": ["type"]
          },
          "then": {
            "required": ["url"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "qr_code" } },
            "required": ["type"]
          },
          "then": {
            "required": ["qrPayload"]
          }
        }
      ]
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
