{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realtimemail.org/schemas/manifest.schema.json",
  "title": "Realtime Mail Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "version", "domain", "displayName", "publicKeys", "channels"],
  "properties": {
    "protocol": {
      "const": "realtime-mail"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "publicKeys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(ed25519|ecdsa-p256):[A-Za-z0-9_-]+={0,2}$"
      }
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/channel"
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "string",
      "enum": [
        "render:html",
        "render:css",
        "render:svg",
        "run:script-sandboxed",
        "open-url:user-gesture",
        "payment-request:user-gesture",
        "storage:isolated",
        "network:domain-only"
      ]
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "route", "capabilities"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "route": {
          "type": "string",
          "pattern": "^/[A-Za-z0-9._~!$&'()*+,;=:@/%-]+$"
        },
        "description": {
          "type": "string",
          "maxLength": 280
        },
        "capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/capability"
          }
        }
      }
    }
  }
}
